# Dependencies — reinstall with `npm install`, never commit
node_modules/

# npm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS cruft
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Packaged extension zips — rebuild from source instead of versioning binaries
*.zip

# Local scratch/test files created during development sessions
*_test.js
test_*.js
integration_test*.js

# Environment/secrets — this extension reads the user's API key from
# chrome.storage.local at runtime, never from a file, but ignore these
# patterns anyway as a safety net in case any local testing script ever
# introduces one
.env
.env.local
*.pem
*.key

# NOTE: lib/tokenizer.bundle.js is INTENTIONALLY NOT ignored. It's a large
# (~2.3MB) build artifact, but Chrome loads it directly at runtime — without
# committing it, a fresh `git clone` would not be a working extension until
# someone ran `npm install && npx esbuild ...` first. Keeping it committed
# means `git clone` + "Load unpacked" always works immediately. See README's
# "Rebuilding the tokenizer bundle" section if you need to regenerate it
# after editing lib/tokenizer.entry.js.
